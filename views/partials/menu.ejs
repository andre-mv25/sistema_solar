<%- include('menu-css') %>

<nav class="navbar">
    <div class="nav-container">
        <a href="/" class="nav-logo">
            <span class="logo-icon">☀️</span>
            <span>Sistema Solar</span>
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Abrir menú">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <ul class="nav-links" id="navLinks">
            <% paginas.forEach(pagina => { %>
                <li>
                    <a href="<%= pagina.ruta %>" class="<%= paginaActual === pagina.ruta ? 'active' : '' %>">
                        <%= pagina.nombre %>
                    </a>
                </li>
            <% }) %>
            <li>
                <a href="/sol" class="<%= paginaActual === '/sol' ? 'active' : '' %>">El Sol</a>
            </li>
            <li class="dropdown">
                <a href="#" class="dropdown-toggle <%= paginaActual && paginaActual.startsWith('/planeta') ? 'active' : '' %>">
                    Planetas <span class="arrow">▼</span>
                </a>
                <ul class="dropdown-menu">
                    <% planetas.forEach(planeta => { %>
                        <li>
                            <a href="/planeta/<%= planeta.slug %>" class="<%= paginaActual === '/planeta/' + planeta.slug ? 'active' : '' %>">
                                <span class="dot" style="background:<%= planeta.color %>"></span>
                                <%= planeta.nombre %>
                            </a>
                        </li>
                    <% }) %>
                </ul>
            </li>
        </ul>
    </div>
</nav>

<script>
(function() {
    var toggle = document.getElementById('navToggle');
    var links = document.getElementById('navLinks');
    var dropdowns = links.querySelectorAll('.dropdown');

    if (toggle) {
        toggle.addEventListener('click', function() {
            this.classList.toggle('active');
            links.classList.toggle('open');
        });
    }

    dropdowns.forEach(function(d) {
        var link = d.querySelector('.dropdown-toggle');
        link.addEventListener('click', function(e) {
            if (window.innerWidth <= 768) {
                e.preventDefault();
                d.classList.toggle('open');
            }
        });
    });

    document.addEventListener('click', function(e) {
        if (toggle && !toggle.contains(e.target) && !links.contains(e.target)) {
            toggle.classList.remove('active');
            links.classList.remove('open');
        }
    });
})();
</script>
