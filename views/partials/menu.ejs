<%- include('menu-css') %>

<nav class="navbar">
    <div class="nav-container">
        <a href="/" class="nav-logo">
            <span class="logo-symbol">✦</span>
            <span>SS</span>
            <span class="logo-full">SISTEMA SOLAR</span>
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Abrir menú">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <div class="nav-overlay" id="navOverlay"></div>
        <ul class="nav-links" id="navLinks">
            <% paginas.forEach(pagina => { %>
                <li>
                    <a href="<%= pagina.ruta %>" class="<%= paginaActual === pagina.ruta ? 'active' : '' %>">
                        <span class="stardust"></span>
                        <%= pagina.nombre %>
                    </a>
                </li>
            <% }) %>
            <li>
                <a href="/sol" class="<%= paginaActual === '/sol' ? 'active' : '' %>">
                    <span class="stardust"></span>
                    El Sol
                </a>
            </li>
            <li class="dropdown">
                <a href="#" class="dropdown-toggle <%= paginaActual && paginaActual.startsWith('/planeta') ? 'active' : '' %>">
                    <span class="stardust"></span>
                    Planetas <span class="dropdown-arrow">▼</span>
                </a>
                <ul class="dropdown-menu">
                    <% planetas.forEach(planeta => { %>
                        <li>
                            <a href="/planeta/<%= planeta.slug %>" class="<%= paginaActual === '/planeta/' + planeta.slug ? 'active' : '' %>">
                                <span class="dot" style="background:<%= planeta.color %>"></span>
                                <%= planeta.nombre %>
                            </a>
                        </li>
                    <% }) %>
                </ul>
            </li>
        </ul>
    </div>
</nav>

<script>
(function() {
    var toggle = document.getElementById('navToggle');
    var links = document.getElementById('navLinks');
    var overlay = document.getElementById('navOverlay');
    var dropdowns = links.querySelectorAll('.dropdown');

    function closeMenu() {
        toggle.classList.remove('active');
        links.classList.remove('open');
        overlay.classList.remove('show');
    }

    function openMenu() {
        toggle.classList.add('active');
        links.classList.add('open');
        overlay.classList.add('show');
    }

    if (toggle) {
        toggle.addEventListener('click', function() {
            links.classList.contains('open') ? closeMenu() : openMenu();
        });
    }

    if (overlay) {
        overlay.addEventListener('click', closeMenu);
    }

    dropdowns.forEach(function(d) {
        var link = d.querySelector('.dropdown-toggle');
        link.addEventListener('click', function(e) {
            if (window.innerWidth <= 768) {
                e.preventDefault();
                d.classList.toggle('open');
            }
        });
    });

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && links.classList.contains('open')) closeMenu();
    });

    links.querySelectorAll('.dropdown-menu a').forEach(function(a) {
        a.addEventListener('click', function() {
            if (window.innerWidth <= 768) closeMenu();
        });
    });

    links.querySelectorAll('a:not(.dropdown-toggle)').forEach(function(a) {
        a.addEventListener('click', function() {
            if (window.innerWidth <= 768 && links.classList.contains('open')) closeMenu();
        });
    });
})();
</script>
