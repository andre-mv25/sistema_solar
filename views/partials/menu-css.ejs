}

@keyframes logoGlow {
    0%, 100% { filter: drop-shadow(0 0 6px rgba(249, 212, 35, 0.3)); transform: scale(1); }
    50% { filter: drop-shadow(0 0 14px rgba(249, 212, 35, 0.6)); transform: scale(1.08); }
}

.logo-text {
    display: flex; flex-direction: column; line-height: 1.1;
}

.logo-text .top {
