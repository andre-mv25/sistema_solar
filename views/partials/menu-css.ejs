    z-index: 1000;
    padding: 0 2rem;
}

.navbar::before {
    content: ''; position: absolute;
    bottom: 0; left: 10%; width: 80%; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(249, 212, 35, 0.15), transparent);
    pointer-events: none;
}

.nav-container {
    max-width: 1100px; margin: 0 auto;
    display: flex; align-items: center;
    justify-content: space-between;
    height: 64px;
}

.nav-logo {
