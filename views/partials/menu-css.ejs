}

.nav-links > li > a.active {
    color: #f9d423;
    background: rgba(249, 212, 35, 0.08);
    box-shadow: inset 0 0 0 1px rgba(249, 212, 35, 0.12);
}

.dropdown { position: relative; }

.dropdown-toggle {
