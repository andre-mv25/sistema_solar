        opacity: 1; visibility: visible;
        transform: none;
        background: rgba(255, 255, 255, 0.02);
        border: none;
        border-top: none;
        padding: 2px 0 2px 8px;
        display: none;
        margin-top: 0;
    }

    .dropdown.open .dropdown-menu { display: block; }

    .stardust { display: none; }
