        -webkit-backdrop-filter: blur(4px);
        z-index: 999;
        opacity: 0; visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
    }

    .nav-overlay.show { opacity: 1; visibility: visible; }

    .nav-links {
