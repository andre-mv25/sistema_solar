<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= planeta.nombre %> | Sistema Solar</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0a0e27 0%, #1a1a3e 50%, #0a0e27 100%);
            color: #fff;
            min-height: 100vh;
            padding: 2rem;
            overflow-x: hidden;
        }

        .navbar {
            position: fixed;
            top: 0; left: 0;
            width: 100%;
            background: rgba(10, 14, 39, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            z-index: 1000;
            padding: 0 2rem;
        }

        .nav-container {
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 60px;
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
            color: #f9d423;
            font-size: 1.2rem;
            font-weight: 600;
            letter-spacing: 1px;
        }

        .logo-icon { font-size: 1.5rem; }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 0.5rem;
            align-items: center;
        }

        .nav-links > li > a {
            text-decoration: none;
            color: rgba(255, 255, 255, 0.7);
            padding: 0.5rem 1.2rem;
            border-radius: 0.5rem;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            letter-spacing: 0.5px;
        }

        .nav-links > li > a:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.08);
        }

        .nav-links > li > a.active {
            color: #f9d423;
            background: rgba(249, 212, 35, 0.1);
        }

        .dropdown { position: relative; }

        .dropdown-toggle {
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .arrow { font-size: 0.6rem; transition: transform 0.3s ease; }

        .dropdown:hover .arrow { transform: rotate(180deg); }

        .dropdown-menu {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            background: rgba(20, 24, 50, 0.95);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0.75rem;
            padding: 0.5rem;
            min-width: 180px;
            list-style: none;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        .dropdown:hover .dropdown-menu { display: block; }

        .dropdown-menu a {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            text-decoration: none;
            color: rgba(255, 255, 255, 0.8);
            padding: 0.6rem 1rem;
            border-radius: 0.5rem;
            font-size: 0.85rem;
            transition: all 0.2s ease;
        }

        .dropdown-menu a:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
        }

        .dropdown-menu a.active {
            color: #f9d423;
            background: rgba(249, 212, 35, 0.1);
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .nav-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
        }

        .nav-toggle span {
            display: block;
            width: 25px;
            height: 2px;
            background: #fff;
            border-radius: 2px;
            transition: all 0.3s ease;
        }

        .stars {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .star {
            position: absolute;
            background: #fff;
            border-radius: 50%;
            animation: twinkle var(--duration) ease-in-out infinite alternate;
        }

        @keyframes twinkle {
            0% { opacity: 0.2; }
            100% { opacity: 1; }
        }

        .container {
            position: relative;
            z-index: 1;
            max-width: 900px;
            margin: 0 auto;
            margin-top: 100px;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: rgba(255, 255, 255, 0.5);
            text-decoration: none;
            font-size: 0.9rem;
            margin-bottom: 2rem;
            transition: color 0.3s ease;
        }

        .back-link:hover { color: #f9d423; }

        .planet-header {
            display: flex;
            align-items: center;
            gap: 3rem;
            margin-bottom: 3rem;
            padding: 2rem;
            border-radius: 1.5rem;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.06);
        }

        .planet-header img {
            width: 200px;
            height: 200px;
            filter: drop-shadow(0 0 40px <%= planeta.color %>80);
            transition: transform 0.5s ease;
        }

        .planet-header:hover img { transform: rotate(10deg) scale(1.05); }

        .planet-info h1 {
            font-size: 2.5rem;
            font-weight: 300;
            letter-spacing: 4px;
            color: <%= planeta.color %>;
            margin-bottom: 0.5rem;
        }

        .planet-info .desc {
            font-size: 1.1rem;
            color: rgba(255, 255, 255, 0.6);
            margin-bottom: 1rem;
        }

        .planet-info .type-badge {
            display: inline-block;
            padding: 0.3rem 1rem;
            border-radius: 2rem;
            font-size: 0.8rem;
            letter-spacing: 1px;
            background: <%= planeta.color %>20;
            color: <%= planeta.color %>;
            border: 1px solid <%= planeta.color %>40;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .stat-card {
            padding: 1.2rem 1.5rem;
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.06);
            transition: transform 0.3s ease, border-color 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-3px);
            border-color: <%= planeta.color %>40;
        }

        .stat-label {
            font-size: 0.75rem;
            color: rgba(255, 255, 255, 0.4);
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 0.3rem;
        }

        .stat-value {
            font-size: 1.1rem;
            font-weight: 500;
            color: #fff;
        }

        .info-section {
            margin-top: 2rem;
            padding: 1.5rem 2rem;
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.06);
            line-height: 1.8;
            font-size: 1rem;
            color: rgba(255, 255, 255, 0.8);
        }

        @media (max-width: 700px) {
            body { padding: 1rem; }
            .planet-header { flex-direction: column; text-align: center; padding: 1.5rem; }
            .planet-header img { width: 150px; height: 150px; }
            .planet-info h1 { font-size: 2rem; }
            .navbar { padding: 0 1rem; }
        }
    </style>
</head>
<body>
    <%- include('partials/menu') %>

    <div class="stars" id="stars"></div>
    <div class="container">
        <a href="/" class="back-link">← Volver al Sistema Solar</a>

        <div class="planet-header">
            <img src="<%= planeta.imagen %>" alt="<%= planeta.nombre %>">
            <div class="planet-info">
                <h1><%= planeta.nombre %></h1>
                <div class="desc"><%= planeta.descripcion %></div>
                <span class="type-badge"><%= planeta.slug === 'sol' ? '' : 'Planeta' %> <%= planeta.tipo %></span>
            </div>
        </div>

        <% if (planeta.slug === 'sol') { %>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Radio</div>
                <div class="stat-value"><%= planeta.radio %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Temperatura superficial</div>
                <div class="stat-value"><%= planeta.temperatura %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Distancia de la Tierra</div>
                <div class="stat-value"><%= planeta.distanciaTierra %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Edad</div>
                <div class="stat-value"><%= planeta.edad %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Masa</div>
                <div class="stat-value"><%= planeta.masa %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Tipo</div>
                <div class="stat-value"><%= planeta.tipo %></div>
            </div>
        </div>
        <% } else { %>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-label">Radio</div>
                <div class="stat-value"><%= planeta.radio %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Distancia del Sol</div>
                <div class="stat-value"><%= planeta.distanciaSol %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Período orbital</div>
                <div class="stat-value"><%= planeta.periodoOrbital %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Lunas</div>
                <div class="stat-value"><%= planeta.lunas %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Gravedad</div>
                <div class="stat-value"><%= planeta.gravedad %></div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Tipo</div>
                <div class="stat-value"><%= planeta.tipo %></div>
            </div>
        </div>
        <% } %>

        <div class="info-section">
            <p><%= planeta.info %></p>
        </div>
    </div>

    <script>
        const starsContainer = document.getElementById('stars');
        for (let i = 0; i < 120; i++) {
            const star = document.createElement('div');
            star.className = 'star';
            const size = Math.random() * 3 + 1;
            star.style.width = size + 'px';
            star.style.height = size + 'px';
            star.style.left = Math.random() * 100 + '%';
            star.style.top = Math.random() * 100 + '%';
            star.style.setProperty('--duration', (Math.random() * 3 + 2) + 's');
            star.style.animationDelay = Math.random() * 5 + 's';
            starsContainer.appendChild(star);
        }
    </script>
</body>
</html>